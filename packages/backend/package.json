{
  "name": "@globular/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",

  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",

  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "prepack": "npm run clean && npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./services": {
      "types": "./dist/services/index.d.ts",
      "default": "./dist/services/index.js"
    },
    "./apps/media": {
      "types": "./dist/apps/media/index.d.ts",
      "default": "./dist/apps/media/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "default": "./dist/ui/index.js"
    }
  },
  "dependencies": {
    "globular-web-client": "link:../../../services/typescript/dist",
    "google-protobuf": "^3.21.0",
    "@types/google-protobuf": "^3.15.0",
    "grpc-web": "^1.4.2",
    "toastify-js": "^1.12.0",
    "@types/toastify-js": "^1.12.4",
    "dom-to-image": "^2.6.0",
    "highlight.js": "^11.11.1",
    "hljs": "^6.2.3",
    "hls.js": "^1.6.14",
    "iptv-playlist-parser": "^0.15.1",
    "jmespath": "^0.16.0",
    "jmespath-edit": "^0.3.2",
    "lodash": "^4.17.21",
    "markdown-it": "14.0.0",
    "plyr": "^3.8.3",
    "uuid": "^13.0.0",
    "uuid-by-string": "^4.0.0",
    "wavesurfer.js": "^7.11.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.4",
    "happy-dom": "^15.11.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.6.3",
    "vitest": "^1.6.0"
  }
}
