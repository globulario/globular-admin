{
  "name": "@globular/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./theme": {
      "types": "./src/theme/index.ts",
      "default": "./src/theme/index.ts"
    },
    "./styles/theme.css": "./src/styles/theme.css",
    "./styles/components.css": "./src/styles/components.css",
    "./styles/base.css": "./src/styles/base.css",
    "./widgets/*": "./src/widgets/*"
  },
  "dependencies": {
    "@globular/sdk": "workspace:*",
    "@globular/components": "workspace:*"
  }
}
